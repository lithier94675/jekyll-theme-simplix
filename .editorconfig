root = true

[*]
charset = utf-8
end_of_line = crlf

[*.{md}]
indent_style = space
indent_size = 2

[*.{html,scss,js,svg,json,gemspec}]
indent_style = tab
indent_size = 2

[Gemfile]
indent_style = tab
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2
insert_final_newline = true
